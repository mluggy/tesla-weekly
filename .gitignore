# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node.js
node_modules/

# Build output
dist/

# Cloudflare Wrangler state
.wrangler/

# OS
**/.DS_Store
Thumbs.db
*.tmp
*.swp

# Secrets / env
.env*
s3/
temp/
.tmp/

# Build-generated (middleware modules)
functions/_html-template.js
functions/_episodes.js
functions/_config.js

# Build-generated (RSS) — public/ is a build copy; episodes/rss.xml is
# the committed canonical source (read back next run to preserve pubDates).
public/rss.xml

# Generated data (rebuilt by scripts/yaml-to-json.js)
public/episodes.json
public/search-index.json

# Generated assets (rebuilt by scripts/generate-og.js)
public/favicon.ico
public/manifest.json
public/apple-touch-icon.png
public/icon-*.png

# Generated by scripts/generate-sitemap.js
public/sitemap.xml
public/robots.txt

# Generated by scripts/generate-llms.js
public/llms.txt
